DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/foodstore
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:5173"]

# MercadoPago — crear cuentas de prueba en https://www.mercadopago.com.ar/developers/panel/app
# Usar las credenciales de la cuenta VENDEDOR de prueba
MP_ACCESS_TOKEN=APP_USR-tu-access-token-de-prueba
MP_PUBLIC_KEY=APP_USR-tu-public-key-de-prueba

# URL publica donde MP enviara los webhooks (usar ngrok en desarrollo local)
# Ejemplo: https://tu-subdominio.ngrok-free.app/api/v1/pagos/webhook
MP_NOTIFICATION_URL=https://tu-ngrok-url/api/v1/pagos/webhook

# Clave secreta del webhook (se obtiene al crear el webhook en el panel MP)
MP_WEBHOOK_SECRET=tu-webhook-secret

# true para modo sandbox (cuentas de prueba), false para produccion
MP_SANDBOX=true

FRONTEND_URL=http://localhost:5173
